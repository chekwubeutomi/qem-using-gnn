*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ------------------------------------------------------------
# Environment & Secrets
# ------------------------------------------------------------
# Never commit API keys, tokens, or credentials
.env
.env.*
!.env.example
*.env
secrets.json
secrets.yaml
secrets.yml
credentials.json
config.local.py
ibm_quantum_token.txt

# IBM Quantum / Qiskit Runtime credentials
qiskit-ibm.json
.qiskit/qiskit-ibm.json


# ------------------------------------------------------------
