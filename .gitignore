# ============================================================
# .gitignore — QEM-GNN Quantum Error Mitigation Project
# ============================================================


# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Profiling
*.prof
*.lprof


# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
vqem/
venv/
env/
.env/
.venv/
ENV/
env.bak/
venv.bak/
Pipfile.lock


# ------------------------------------------------------------
# Project — Model Checkpoints & Weights
# ------------------------------------------------------------
# Saved PyTorch model files can be large (100MB+)
# Use Git LFS or a model registry (e.g. HuggingFace Hub) instead
*.pt
*.pth
*.ckpt
*.bin

# Keep the directory structure but not the files
!models/.gitkeep


# ------------------------------------------------------------
# Project — Datasets
# ------------------------------------------------------------
# JSON datasets can be very large depending on num_circuits
# Store them in cloud storage or DVC instead
*.json
# Re-include small config/metadata JSON files that should be tracked
!pyproject.json
!package.json

# NumPy binary files (normalisation stats, arrays)
*.npy
*.npz


# ------------------------------------------------------------
# Project — Training Outputs & Logs
# ------------------------------------------------------------
*.history.json
*.norm.npz
*.log
logs/
runs/
tensorboard/
wandb/
mlruns/

# Training plots and figures
*.png
*.jpg
*.jpeg
*.svg
*.pdf
# Re-include documentation images if you have any
!docs/**/*.png
!docs/**/*.jpg
!assets/**/*.png
!assets/**/*.jpg

*.pt
*.npz


# ------------------------------------------------------------
# Project — Qiskit / Quantum Circuit Outputs
# ------------------------------------------------------------
# OpenQASM files exported during experimentation
*.qasm

# Qiskit job result caches
qiskit_cache/
.qiskit/


# ------------------------------------------------------------
# Jupyter Notebooks
# ------------------------------------------------------------
# Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Notebook output cells stripped (optional — uncomment if preferred)
# *.ipynb


