.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Spyder
.spyderproject.db
.spyproject/

# Rope
.ropeproject/

# Eclipse
.project
.pydevproject
.settings/
.classpath

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*


